# ============================================================
# .env.example – Salin file ini menjadi .env dan isi nilainya
# ============================================================

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...your-openai-key-here...

# ── Anthropic (Opsional) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...

# ── Instagram / Meta Graph API ───────────────────────────────
# OPSI A (direkomendasikan): OAuth via browser.
#   1. Buat Facebook App di https://developers.facebook.com/apps/
#      (tipe: Business), aktifkan produk "Facebook Login" & "Instagram Graph API".
#   2. Di Facebook Login → Settings, tambahkan Valid OAuth Redirect URI:
#        http://localhost:8765/callback
#   3. Isi App ID & Secret di bawah, lalu jalankan:
#        python main.py auth instagram
#      Token & IG Business Account ID akan tersimpan otomatis di
#      data/auth/instagram.json (tidak perlu isi META_ACCESS_TOKEN manual).
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
OAUTH_REDIRECT_URI=http://localhost:8765/callback

# OPSI B (manual): isi token & ID langsung jika sudah punya dari Graph API Explorer.
META_ACCESS_TOKEN=EAAVjz0FjeX4BRb9RI7qsBb0ZCFsfwc3PzY3v4ZBEMNsjCObvukhbK5whImzSsCYE4il8Cc9TOAvkGLXkdlIFNbkJTNY4QxW4Cq6Et7sUjNLphQAjSmPSCExkZB2cOkUzGwY1Nxoef5sTYX8oF5rb5w1saAybJ9bZB5vUoQtfufTbl5QUnJSXa0Q727x96ZCKk8SCUUl269YjQwUYAeMZCPD1o1m7E0ZA4Vq9QFKSnbhE51P9gd5IgVi9kX6ygauXMAUifA6gcozLqn4uiPJ5ZBGoBbNbwwZDZD
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# OPSI C (fallback unofficial, akun personal): pakai instagrapi.
INSTAGRAM_USERNAME=casha_app
INSTAGRAM_PASSWORD=

# ── TikTok ──────────────────────────────────────────────────
TIKTOK_SESSION_ID=your-tiktok-session-id
TIKTOK_MS_TOKEN=your-tiktok-ms-token

# ── LinkedIn ─────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_ORGANIZATION_ID=your-linkedin-org-id

# ── Notifikasi (Opsional) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# ── Database (Opsional untuk persistence) ────────────────────
DATABASE_URL=sqlite:///data/cmo.db
